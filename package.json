{
  "name": "agents-skills",
  "version": "1.0.8",
  "description": "Cross-IDE agent scaffolding: install rules, skills, workflows and hooks for Antigravity, VS Code, Cursor, and Claude Code",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bhargavgandhi/agentic-workflows.git"
  },
  "homepage": "https://bhargavgandhi.github.io/agentic-workflows/",
  "bugs": {
    "url": "https://github.com/bhargavgandhi/agentic-workflows/issues"
  },
  "bin": {
    "agents-skills": "bin/cli.js"
  },
  "files": [
    "bin/",
    "src/",
    ".agents/",
    "skills/",
    "skills.json"
  ],
  "scripts": {
    "start": "node ./bin/cli.js",
    "code-review": "./hooks/code-review.sh",
    "setup:hooks": "git config core.hooksPath hooks",
    "version:patch": "npm version patch",
    "publish:package": "npm publish --access public",
    "prepublishOnly": "rm -rf skills && cp -r .agents/skills skills"
  },
  "keywords": [
    "agent",
    "ai",
    "rules",
    "skills",
    "cursor",
    "copilot",
    "claude",
    "antigravity",
    "workflow",
    "scaffolding"
  ],
  "author": "Bhargav Gandhi",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "gray-matter": "^4.0.3",
    "picocolors": "^1.1.1"
  }
}
